    "notify_on_task_complete": true,
    "notify_on_story_complete": false,
    "notify_on_failure": true,
    "notify_on_escalation": true,
    "notify_on_human_action": true
  },
  "metrics": {
    "enabled": true,
    "exporter_port": 9101,
    "export_interval_seconds": 60
  }
}
