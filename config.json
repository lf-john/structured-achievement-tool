{
  "routing_strategy": "complexity_based",
  "default_primary": "sonnet",
  "default_backup": "deepseek_r1",
  "routing_rules_enabled": true,
  "phase_models": {},
  "execution": {
    "max_retries_per_story": 5,
    "max_phase_retries": 10,
    "use_worktree": false,
    "enable_mediator": true,
    "checkpoint_db": ".memory/checkpoints.db"
  },
  "routing_preferences": {
    "reasoning_primary": "sonnet",
    "reasoning_backup": "deepseek_r1",
    "code_primary": "sonnet",
    "code_backup": "qwen25_coder",
    "classification_primary": "qwen3_8b",
    "classification_backup": "nemotron"
  },
  "proactive_agency": {
    "enabled": true,
    "maintenance_interval_hours": 168,
    "dependency_check_interval_hours": 336,
    "config_validation_interval_hours": 24,
    "story_output_dir": "~/GoogleDrive/DriveSyncFiles/sat-tasks/maintenance"
  },
  "progress_bar": {
    "enabled": true,
    "update_on_story_complete": true,
    "update_on_phase_transition": false
  },
  "notifications": {
    "ntfy_enabled": true,
    "ntfy_min_priority": "high",
